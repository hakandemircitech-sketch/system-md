## 5. KODLAMA STANDARTLARI

### TypeScript
- strict: true — any KULLANMA
- Her fonksiyon için dönüş tipi belirt
- Supabase DB tipleri: types/database.ts'den import et
- API response'ları için tip güvenli olsun

### Bileşen Yazımı
```typescript
// DOĞRU — fonksiyonel bileşen + açık prop tipi
interface ButtonProps {
  variant?: 'primary' | 'secondary' | 'danger' | 'ghost'
  size?: 'xs' | 'sm' | 'md' | 'lg'
  loading?: boolean
  children: React.ReactNode
  onClick?: () => void
}
export function Button({ variant = 'primary', size = 'md', ...props }: ButtonProps) { ... }

// YANLIŞ — isimsiz export, tip yok
export default ({ children, ...props }) => { ... }
```

### API Routes
```typescript
// DAIMA: tip güvenli request/response
// DAIMA: try/catch ile hata yönetimi
// DAIMA: auth kontrolü başta
export async function POST(req: Request) {
  try {
    const supabase = createServerClient()
    const { data: { user } } = await supabase.auth.getUser()
    if (!user) return Response.json({ error: 'Yetkisiz erişim' }, { status: 401 })

    const body = await req.json()
    // ... işlem
    return Response.json({ data: result })
  } catch (error) {
    console.error('[API] Hata:', error)
    return Response.json({ error: 'Sunucu hatası' }, { status: 500 })
  }
}
```

### Supabase Sorguları
```typescript
// DAIMA: .select() ile sütun belirt (SELECT * KULLANMA)
// DAIMA: hata kontrolü yap
const { data, error } = await supabase
  .from('blueprints')
  .select('id, title, score_total, created_at')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false })

if (error) throw new Error(error.message)
```

### Claude API Çağrıları
```typescript
// DAIMA: streaming kullan (uzun üretimler için)
// DAIMA: structured output için JSON prompt
// DAIMA: token kullanımını logla
const stream = await anthropic.messages.stream({
  model: 'claude-sonnet-4-6',
  max_tokens: 8192,
  system: SYSTEM_PROMPT,
  messages: [{ role: 'user', content: prompt }]
})
```

